{
  "name": "@smolsoftboi/monzo-codex-plugin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Unofficial Codex MCP plugin for the Monzo Developer API.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/index.ts",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "test": "node --test --import tsx \"tests/*.test.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  }
}
